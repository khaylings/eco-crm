# --- Firebase ---
VITE_FIREBASE_API_KEY=tu-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=eco-crm-da4eb.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=eco-crm-da4eb
VITE_FIREBASE_STORAGE_BUCKET=eco-crm-da4eb.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=tu-sender-id
VITE_FIREBASE_APP_ID=tu-app-id

# --- Encriptación AES-256 ---
# Genera una clave aleatoria fuerte (mínimo 32 caracteres)
# Ejemplo: openssl rand -base64 32
# NUNCA uses una clave débil en producción
VITE_CRYPTO_SECRET=CAMBIA-ESTO-POR-UNA-CLAVE-ALEATORIA-DE-32-CHARS

# --- Entorno ---
VITE_APP_ENV=production
VITE_APP_VERSION=1.0.0
