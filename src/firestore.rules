// ==============================================================
// LK-CRM — Firestore Security Rules
// Copyright (c) 2024 LK-CRM. Todos los derechos reservados.
//
// Archivo: firestore.rules
// Estas reglas controlan quién puede leer/escribir qué datos.
// IMPORTANTE: Deployar con: firebase deploy --only firestore:rules
// ==============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------
    // Funciones auxiliares
    // -------------------------------------------------------

    // Verifica si el usuario está autenticado
    function isAuth() {
      return request.auth != null;
    }

    // Verifica si el usuario tiene rol "admin" en Firestore
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'admin';
    }

    // Verifica si el usuario tiene rol "admin" o "supervisor"
    function isSupervisorOrAdmin() {
      return isAuth() && (
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in ['admin', 'supervisor']
      );
    }

    // Verifica que el usuario pertenece a la misma empresa
    function sameEmpresa(empresaId) {
      return isAuth() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.empresaId == empresaId;
    }

    // -------------------------------------------------------
    // CRÍTICO: Configuración segura (API keys encriptadas)
    // Solo admins pueden leer/escribir
    // -------------------------------------------------------
    match /configuracion_segura/{docId} {
      allow read, write: if isAdmin();
    }

    // -------------------------------------------------------
    // Usuarios del sistema
    // -------------------------------------------------------
    match /usuarios/{userId} {
      // Cualquier usuario autenticado puede leer perfiles (necesario para mostrar nombres/avatares)
      allow read: if isAuth();
      // Solo admins pueden crear/modificar usuarios
      allow write: if isAdmin();
      // Subcolecciones del usuario (stickers, etc.) — solo el propio usuario
      match /{subCol}/{subDoc} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // -------------------------------------------------------
    // Datos operativos (leads, contactos, cotizaciones, etc.)
    // Cualquier usuario autenticado puede operar
    // -------------------------------------------------------
    match /leads/{docId} {
      allow read, write: if isAuth();
    }

    match /contactos/{docId} {
      allow read, write: if isAuth();
    }

    match /empresas/{docId} {
      allow read, write: if isAuth();
    }

    match /cotizaciones/{docId} {
      allow read: if true;  // Lectura pública — necesaria para el portal del cliente
      allow write: if isAuth();
      match /items/{itemId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    match /productos/{docId} {
      allow read, write: if isAuth();
    }

    match /inventario/{docId} {
      allow read, write: if isAuth();
      match /movimientos/{movId} {
        allow read, write: if isAuth();
      }
    }

    match /conversaciones/{docId} {
      allow read, write: if isAuth();
      match /mensajes/{msgId} {
        allow read, write: if isAuth();
      }
    }

    match /calendario/{docId} {
      allow read, write: if isAuth();
    }

    match /proveedores/{docId} {
      allow read, write: if isAuth();
    }

    // -------------------------------------------------------
    // Configuración general (no sensible)
    // Solo admins pueden modificar, todos pueden leer
    // -------------------------------------------------------
    match /configuracion/{docId} {
      // empresa y plantilla_cotizacion necesitan lectura pública para el portal del cliente
      allow read: if true;
      allow write: if isAdmin();
    }

    // Catálogos editables (etiquetas, categorías, etc.)
    match /catalogos/{docId} {
      allow read: if isAuth();
      allow write: if isSupervisorOrAdmin();
    }

    // -------------------------------------------------------
    // Catálogos individuales (origenes, sectores, tipos, etc.)
    // -------------------------------------------------------
    match /catalogo_origenes/{docId} {
      allow read: if isAuth();
      allow write: if isSupervisorOrAdmin();
    }
    match /catalogo_sectores/{docId} {
      allow read: if isAuth();
      allow write: if isSupervisorOrAdmin();
    }
    match /catalogo_tipos_equipo/{docId} {
      allow read: if isAuth();
      allow write: if isSupervisorOrAdmin();
    }
    match /catalogo_tipos_servicio/{docId} {
      allow read: if isAuth();
      allow write: if isSupervisorOrAdmin();
    }
    match /catalogo_estados_equipo/{docId} {
      allow read: if isAuth();
      allow write: if isSupervisorOrAdmin();
    }
    match /catalogo_filtros_calendario/{docId} {
      allow read: if isAuth();
      allow write: if isSupervisorOrAdmin();
    }

    // -------------------------------------------------------
    // Chats internos
    // -------------------------------------------------------
    match /chats_internos/{chatId} {
      allow read, write: if isAuth();
      match /mensajes/{msgId} {
        allow read, write: if isAuth();
      }
    }

    // -------------------------------------------------------
    // Pipeline CRM
    // -------------------------------------------------------
    match /pipeline_columnas/{docId} {
      allow read: if isAuth();
      allow write: if isSupervisorOrAdmin();
    }

    // -------------------------------------------------------
    // Roles y permisos
    // -------------------------------------------------------
    match /roles/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------
    // Facturación y finanzas
    // -------------------------------------------------------
    match /facturas/{docId} {
      allow read, write: if isAuth();
    }

    match /cuentas_bancarias/{docId} {
      allow read, write: if isAuth();
    }

    match /movimientos_bancarios/{docId} {
      allow read, write: if isAuth();
    }

    match /deudas/{docId} {
      allow read, write: if isAuth();
    }

    // -------------------------------------------------------
    // Compras y gastos
    // -------------------------------------------------------
    match /ordenes_compra/{docId} {
      allow read, write: if isAuth();
    }

    match /gastos_recurrentes/{docId} {
      allow read, write: if isAuth();
    }

    // -------------------------------------------------------
    // Proyectos
    // -------------------------------------------------------
    match /proyectos/{docId} {
      allow read, write: if isAuth();
      match /{subCol}/{subDoc} {
        allow read, write: if isAuth();
      }
    }

    // -------------------------------------------------------
    // Activos (inventario físico / equipos)
    // -------------------------------------------------------
    match /activos/{docId} {
      allow read, write: if isAuth();
      match /{subCol}/{subDoc} {
        allow read, write: if isAuth();
      }
    }

    match /movimientosInventario/{docId} {
      allow read, write: if isAuth();
    }

    // -------------------------------------------------------
    // Eventos de calendario
    // -------------------------------------------------------
    match /eventos/{docId} {
      allow read, write: if isAuth();
    }

    // -------------------------------------------------------
    // Correo electrónico
    // -------------------------------------------------------
    match /emails/{docId} {
      allow read, write: if isAuth();
      match /{subCol}/{subDoc} {
        allow read, write: if isAuth();
      }
    }

    // -------------------------------------------------------
    // Notificaciones internas
    // -------------------------------------------------------
    match /notificaciones/{docId} {
      allow read, write: if isAuth();
    }

    match /zumbidos/{docId} {
      allow read, write: if isAuth();
    }

    // -------------------------------------------------------
    // Colecciones legacy / alias
    // -------------------------------------------------------
    match /clientes/{docId} {
      allow read, write: if isAuth();
    }

    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------
    // Solicitudes internas (bugs y mejoras)
    // Cualquier usuario autenticado puede crear.
    // Cada usuario solo lee las suyas; Super Administrador lee todas.
    // Solo Super Administrador puede actualizar el estado.
    // -------------------------------------------------------
    match /solicitudes/{docId} {
      allow create: if isAuth();
      allow read: if isAuth() && (
        resource.data.creadoPor == request.auth.uid ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'Super Administrador'
      );
      allow update: if isAuth() &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'Super Administrador';
      allow delete: if false;
    }

    // -------------------------------------------------------
    // Colecciones no listadas — acceso a usuarios autenticados
    // Las colecciones sensibles tienen reglas explícitas arriba.
    // -------------------------------------------------------
    match /{document=**} {
      allow read, write: if isAuth();
    }
  }
}
