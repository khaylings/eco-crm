# --- CRÍTICO: Variables de entorno (nunca al repo) ---
.env
.env.local
.env.*.local
.env.production
.env.staging

# --- Build output ---
dist/
dist-ssr/
build/

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Editor ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Sistema operativo ---
.DS_Store
Thumbs.db

# --- Firebase ---
.firebase/
firebase-debug.log
firestore-debug.log

# --- Archivos sensibles varios ---
*.pem
*.key
*.cert
secrets/
private/
serviceAccount.json

# --- Logs ---
logs/
*.log